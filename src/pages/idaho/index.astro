---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Idaho Ski Resorts — Ski Slop" description="Ski resorts in Idaho — scanned and enriched by Ski Slop agents.">
  <section class="container detail-hero">
    <h1>Idaho ski resorts</h1>
    <p>
      Ski Slop agents scan OpenStreetMap across Idaho, normalize resort data with Workers AI,
      and publish listings here automatically.
    </p>

    <div id="region-status" class="stats">
      <p class="loading">Loading Idaho resort data…</p>
    </div>

    <div class="search-bar">
      <a class="btn btn-secondary" href="/resorts/?region=us-id">Browse API list</a>
    </div>
  </section>

  <section class="container">
    <h2 class="section-title">Resorts in Idaho</h2>
    <div id="idaho-resorts" class="card-grid">
      <p class="loading">Loading resorts…</p>
    </div>
  </section>
</Layout>

<script>
  const statusEl = document.getElementById("region-status");
  const listEl = document.getElementById("idaho-resorts");

  async function loadIdaho() {
    try {
      const [regionRes, resortsRes] = await Promise.all([
        fetch("/api/regions/us-id"),
        fetch("/api/resorts/?region=us-id&limit=100"),
      ]);

      const regionData = await regionRes.json();
      const resortsData = await resortsRes.json();

      if (statusEl && regionData.region) {
        const r = regionData.region;
        statusEl.innerHTML = `
          <div class="stat"><strong>${regionData.resort_count}</strong><span>Resorts listed</span></div>
          <div class="stat"><strong>${regionData.rental_count}</strong><span>Rental shops</span></div>
          <div class="stat"><strong>${r.enrichment_status ?? "pending"}</strong><span>Agent status</span></div>
          <div class="stat"><strong>${r.last_enriched_at ? new Date(r.last_enriched_at).toLocaleDateString() : "Never"}</strong><span>Last scan</span></div>
        `;
      }

      const resorts = resortsData.resorts ?? [];
      if (!listEl) return;

      if (!resorts.length) {
        listEl.innerHTML =
          '<p class="empty">No Idaho resorts yet. Trigger the enrichment agent to scan the state (see README).</p>';
        return;
      }

      listEl.innerHTML = resorts
        .map(
          (resort: {
            slug: string;
            name: string;
            trail_count: number;
            elevation_ft: number;
            summary: string;
            source: string;
          }) =>
            `<article class="card">
              <h3><a href="/resorts/${resort.slug}/">${resort.name}</a></h3>
              <p class="meta">${resort.source ?? "manual"} · ${resort.trail_count ?? "?"} trails · ${resort.elevation_ft ?? "?"} ft</p>
              <p>${(resort.summary ?? "").slice(0, 140)}</p>
            </article>`,
        )
        .join("");
    } catch {
      if (listEl) listEl.innerHTML = '<p class="empty">Failed to load Idaho resorts.</p>';
    }
  }

  loadIdaho();
</script>
