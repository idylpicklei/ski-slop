---
import Layout from "../../layouts/Layout.astro";
import { FLAGSHIP_RESORTS } from "../../../shared/resorts-seed";

export function getStaticPaths() {
  return FLAGSHIP_RESORTS.map((resort) => ({
    params: { slug: resort.slug },
    props: { resort },
  }));
}

const { resort } = Astro.props;
---

<Layout title={`${resort.name} — Skier Slop`} description={resort.summary}>
  <section class="container detail-hero">
    <h1>{resort.name}</h1>
    <p class="meta">{resort.region_slug.toUpperCase()}</p>
    <p>{resort.summary}</p>

    <div class="stats">
      <div class="stat">
        <strong>{resort.trail_count}</strong>
        <span>Trails</span>
      </div>
      <div class="stat">
        <strong>{resort.elevation_ft.toLocaleString()}</strong>
        <span>Summit (ft)</span>
      </div>
      <div class="stat">
        <strong>{resort.lat.toFixed(2)}°, {resort.lng.toFixed(2)}°</strong>
        <span>Coordinates</span>
      </div>
    </div>

    {resort.website && (
      <p><a class="btn" href={resort.website} target="_blank" rel="noopener">Official website</a></p>
    )}
  </section>

  <section class="container">
    <h2 class="section-title">Nearby resorts</h2>
    <div id="nearby-resorts" class="card-grid card-grid-compact">
      <p class="loading">Loading nearby resorts…</p>
    </div>
  </section>

  <section class="container">
    <div class="section-header">
      <h2 class="section-title">Nearby rentals</h2>
      <select id="rental-sort" aria-label="Sort rentals">
        <option value="value" selected>Best value</option>
        <option value="price">Cheapest</option>
        <option value="distance">Closest</option>
      </select>
    </div>
    <div id="nearby-rentals" class="card-grid">
      <p class="loading">Loading nearby rentals…</p>
    </div>
  </section>
</Layout>

<script is:inline src="/js/resort-detail.js"></script>
<script is:inline define:vars={{ slug: resort.slug, lat: resort.lat, lng: resort.lng }}>
  initResortDetailPage(slug, lat, lng);
</script>
