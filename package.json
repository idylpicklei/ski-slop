{
  "name": "ski-slop",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "pages:dev": "npm run build && wrangler pages dev dist",
    "deploy:pages": "npm run build && wrangler pages deploy dist --project-name=ski-slop",
    "deploy:agents": "wrangler deploy -c wrangler.agents.jsonc",
    "db:migrate:local": "wrangler d1 migrations apply ski-slop-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply ski-slop-db --remote",
    "db:create": "wrangler d1 create ski-slop-db",
    "types": "wrangler types",
    "check": "astro check && tsc --noEmit -p tsconfig.workers.json"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "agents": "^0.0.113",
    "astro": "^5.7.10"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250317.0",
    "typescript": "^5.8.2",
    "wrangler": "^4.6.0"
  }
}
